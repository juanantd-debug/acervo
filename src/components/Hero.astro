---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="relative min-h-screen overflow-hidden bg-[var(--color-cream)] pt-20">
  <!-- Vídeo de fondo -->
 <!-- Imagen de fondo -->
  <img
    src={`${base}/images/hero.jpg`}
    alt=""
    class="absolute inset-0 z-0 h-full w-full object-cover"
    aria-hidden="true"
  />

  <!-- Velo para legibilidad (paleta crema) -->
  <div class="absolute inset-0 z-10 bg-[var(--color-cream)]/70"></div>

  <div class="container-acervo relative z-20 flex min-h-[calc(100vh-5rem)] items-center">
    <div class="w-full py-20 lg:py-24">
      <p class="mb-6 text-lg font-semibold uppercase tracking-[0.28em] text-[var(--color-gold)]">
        ACERVO LexFin
      </p>

      <h1 class="mb-8 max-w-6xl text-5xl font-semibold tracking-tight text-[var(--color-navy)] md:text-6xl lg:text-7xl xl:text-[5.2rem]">
        Dirección jurídico-financiera para decisiones complejas.
      </h1>

      <p class="mb-8 max-w-4xl text-2xl leading-8 text-[var(--color-charcoal)] md:text-3xl md:leading-9">
        Convertimos decisiones complejas de empresa y activos en planes claros y ejecutables,
        con control del riesgo y máxima previsibilidad.
      </p>

<div class="mb-12 flex flex-col gap-4 sm:flex-row">
        <a href="#contacto" class="inline-flex items-center justify-center rounded-full bg-[var(--color-navy)] px-7 py-3 text-lg font-semibold text-white shadow-sm transition hover:bg-[var(--color-charcoal)] focus:outline-none focus:ring-2 focus:ring-[var(--color-gold)] focus:ring-offset-2">Solicitar diagnóstico</a>
        <a href="#soluciones" class="inline-flex items-center justify-center rounded-full border border-[var(--color-navy)]/20 px-7 py-3 text-lg font-semibold text-[var(--color-navy)] transition hover:bg-[var(--color-navy)]/5">Ver soluciones</a>
      </div>

      <div class="grid max-w-5xl gap-x-12 gap-y-5 text-xl leading-7 text-[var(--color-charcoal)]/80 md:grid-cols-2">
        <p>
          <span class="font-semibold text-[var(--color-navy)]">Gobernanza y estructura:</span>
          <span> decisiones societarias y acuerdos con ejecución sólida.</span>
        </p>

        <p>
          <span class="font-semibold text-[var(--color-navy)]">Dirección financiera externa:</span>
          <span> cuadro de mando y hoja de ruta para decidir con previsibilidad.</span>
        </p>

        <p>
          <span class="font-semibold text-[var(--color-navy)]">Activos y riesgo:</span>
          <span> inmobiliario, urbanismo, registro, subastas y créditos dudosos.</span>
        </p>

        <p>
          <span class="font-semibold text-[var(--color-navy)]">Laboral estratégico:</span>
          <span> estructura laboral, políticas, contingencias y litigación.</span>
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document
      .querySelectorAll<HTMLVideoElement>('video[data-hero]')
      .forEach((v) => v.pause());
  }
</script>