---
import { withBase } from '../lib/withBase';

const navItems = [
  { label: 'Capacidades', href: '/#capacidades' },  
    { label: 'Método', href: '/#metodo' },
  { label: 'Soluciones', href: '/#soluciones' },
  { label: 'Sobre', href: '/#sobre' },
  { label: 'Contacto', href: '/#contacto' },
];
---

<header class="fixed left-0 top-0 z-50 w-full border-b border-[var(--color-navy)]/10 bg-[var(--color-cream)]/85 backdrop-blur-xl">
  <div class="container-acervo flex h-20 items-center justify-between">
    <a href={withBase('/')} class="group flex items-center gap-3" aria-label="Ir al inicio">
      <div class="flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-navy)]/15 bg-white">
        <span class="font-serif text-xl font-bold text-[var(--color-navy)]">A</span>
      </div>

      <div class="leading-none">
        <p class="text-base font-semibold uppercase tracking-[0.24em] text-[var(--color-navy)]">
          ACERVO
        </p>
        <p class="mt-1 text-sm font-medium uppercase tracking-[0.34em] text-[var(--color-charcoal)]">
          LexFin
        </p>
      </div>
    </a>

    <!-- Navegación desktop -->
    <nav class="hidden items-center gap-8 lg:flex" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a
          href={withBase(item.href)}
          class="text-lg font-medium text-[var(--color-charcoal)] transition hover:text-[var(--color-navy)]"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- CTA desktop -->
    <a
      href={withBase('/#contacto')}
      class="hidden rounded-full bg-[var(--color-navy)] px-5 py-2.5 text-base font-semibold text-white transition hover:bg-[var(--color-charcoal)] lg:inline-flex"
    >
      Solicitar diagnóstico
    </a>

    <!-- Botón móvil -->
    <button
      id="menu-button"
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[var(--color-navy)]/15 bg-white text-[var(--color-navy)] lg:hidden"
      aria-label="Abrir menú de navegación"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="sr-only">Abrir menú</span>
      <span class="block h-0.5 w-5 bg-current"></span>
    </button>
  </div>

  <!-- Menú móvil -->
  <div id="mobile-menu" class="hidden border-t border-[var(--color-navy)]/10 bg-[var(--color-cream)] lg:hidden">
    <nav class="container-acervo flex flex-col gap-1 py-5" aria-label="Navegación móvil">
      {navItems.map((item) => (
        <a
          href={withBase(item.href)}
          class="rounded-xl px-3 py-3 text-lg font-medium text-[var(--color-charcoal)] transition hover:bg-white"
        >
          {item.label}
        </a>
      ))}

      <a
        href={withBase('/#contacto')}
        class="mt-3 inline-flex items-center justify-center rounded-full bg-[var(--color-navy)] px-5 py-3 text-base font-semibold text-white"
      >
        Solicitar diagnóstico
      </a>
    </nav>
  </div>

  <script>
    const button = document.querySelector('#menu-button');
    const menu = document.querySelector('#mobile-menu');

    button?.addEventListener('click', () => {
      const isOpen = button.getAttribute('aria-expanded') === 'true';

      button.setAttribute('aria-expanded', String(!isOpen));
      menu?.classList.toggle('hidden');
    });
  </script>
</header>