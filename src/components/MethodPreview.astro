---
const steps = [
  {
    number: '01',
    title: 'Diagnóstico',
    description:
      'Identificamos la decisión, el riesgo, la documentación disponible, las partes implicadas y los próximos hitos relevantes.',
  },
  {
    number: '02',
    title: 'Plan ejecutable',
    description:
      'Convertimos el análisis en una hoja de ruta con entregables, responsables, prioridades y criterios de control.',
  },
  {
    number: '03',
    title: 'Ejecución y control documental',
    description:
      'Ordenamos versiones, evidencias, circuitos de revisión, firma y cierre para reducir errores y mejorar trazabilidad.',
  },
];
---

<section id="metodo" class="section-acervo bg-[var(--color-cream)]">
  <div class="container-acervo">
    <div class="grid gap-14 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div>
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-gold)]">
          Método
        </p>

        <h2 class="mb-6 text-4xl font-semibold tracking-tight text-[var(--color-navy)] md:text-5xl">
          Claridad, ejecución y trazabilidad desde el primer diagnóstico.
        </h2>

        <p class="text-lg text-[var(--color-charcoal)]/80">
          Cada asunto se ordena mediante diagnóstico, plan, entregables y control documental.
          El objetivo es reducir improvisación, anticipar riesgos y convertir la decisión en una
          hoja de ruta ejecutable.
        </p>
      </div>

      <div class="rounded-[2rem] border border-[var(--color-navy)]/10 bg-white p-8 shadow-xl shadow-[var(--color-navy)]/8">
        <div class="mb-8 flex items-center justify-between">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[var(--color-gold)]">
            Forma de trabajo
          </p>

          <span class="h-2 w-2 rounded-full bg-[var(--color-gold)]"></span>
        </div>

        <div class="space-y-0">
          {steps.map((step, index) => (
            <div class={index === steps.length - 1 ? 'py-6' : 'border-b border-[var(--color-navy)]/10 py-6'}>
              <div class="mb-4 flex items-center gap-4">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[var(--color-navy)] text-xs font-semibold text-white">
                  {step.number}
                </span>

                <h3 class="text-[1.65rem] font-semibold leading-tight text-[var(--color-navy)]">
                  {step.title}
                </h3>
              </div>

              <p class="pl-14 text-[15px] leading-7 text-[var(--color-charcoal)]/75">
                {step.description}
              </p>
            </div>
          ))}
        </div>

        <div class="mt-8 rounded-2xl bg-[var(--color-navy)] p-6 text-white">
          <p class="mb-2 font-serif text-3xl font-semibold">
            Legal Ops
          </p>

          <p class="text-[15px] leading-7 text-white/80">
            Gobierno documental, trazabilidad de decisiones, circuitos de revisión y expediente
            de evidencias para reducir error y acelerar cierres.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>